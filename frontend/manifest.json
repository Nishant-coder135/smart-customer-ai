    },
    {
      "src": "assets/icon-192-v2.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "assets/icon-512-v2.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "assets/icon-512-v2.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "shortcuts": [
    {
      "name": "Dashboard",
      "short_name": "Dash",
      "description": "View your business dashboard",
      "url": "./?tab=dashboard",
      "icons": [{ "src": "assets/icon-192-v2.png", "sizes": "192x192" }]
    },
    {
      "name": "Log Sale",
      "short_name": "Add Sale",
      "description": "Log a new transaction",
      "url": "./?tab=data",
      "icons": [{ "src": "assets/icon-192-v2.png", "sizes": "192x192" }]
    },
    {
      "name": "AI Advisor",
      "short_name": "Advisor",
      "description": "Get AI business strategy",
      "url": "./?tab=advisor",
      "icons": [{ "src": "assets/icon-192-v2.png", "sizes": "192x192" }]
    }
  ],
  "display_override": ["standalone", "tabbed", "window-controls-overlay"],
  "screenshots": [
    {
      "src": "assets/icon-512-v2.png",
      "sizes": "512x512",
      "type": "image/png",
      "form_factor": "wide",
      "label": "SmartCustomer AI Workspace"
    },
    {
      "src": "assets/icon-512-v2.png",
      "sizes": "512x512",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "SmartCustomer AI Mobile"
    }
  ],
  "share_target": {
    "action": "./",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "launch_handler": {
    "client_mode": ["navigate-existing", "auto"]
  },
  "edge_side_panel": {
    "preferred_width": 400
  },
  "prefer_related_applications": false,
  "related_applications": [
    {
      "platform": "play",
      "url": "https://play.google.com/store/apps/details?id=com.smartcustomerai.app",
      "id": "com.smartcustomerai.app"
    }
  ],
  "iarc_rating_id": "e84b072d-71b3-4d3e-86ae-31a8ce4e53b7",
  "scope_extensions": [
    {
      "origin": "https://smart-customer-ai-7.onrender.com"
    }
  ],
  "file_handlers": [
    {
      "action": "./",
      "accept": {
        "text/csv": [".csv"],
        "application/json": [".json"]
      }
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "web+smartcustomer",
      "url": "./?action=%s"
    }
  ],
  "widgets": [
    {
      "name": "SmartCustomer AI Snapshot",
      "description": "Quick view of business performance",
      "tag": "dashboard-widget",
      "ms_ac_template": "assets/template.json",
      "data": "assets/data.json",
      "type": "application/json",
      "screenshots": [
        {
          "src": "assets/icon-512-v2.png",
          "sizes": "512x512",
          "type": "image/png",
          "label": "SmartCustomer AI Widget Preview"
        }
      ],
      "icons": [
        {
          "src": "assets/icon-192-v2.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ],
      "auth": false,
      "update": 86400
    }
  ],
  "note_taking": {
    "new_note_url": "./?action=new_note"
  }
}
